import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt

# 1. Load Titanic dataset [cite: 11, 37]
# Note: Ensure you have 'titanic.csv' in your directory or use seaborn's built-in version
df = sns.load_dataset('titanic')

# 2. Data Cleaning [cite: 12, 28]
# Handling missing values for 'Age' by filling with the median [cite: 12]
df['age'] = df['age'].fillna(df['age'].median())

# Dropping 'deck' due to high number of missing values and 'embark_town' rows with NAs
df.drop(columns=['deck'], inplace=True)
df.dropna(subset=['embark_town'], inplace=True)

# 3. Exploratory Data Analysis (EDA) [cite: 13, 29]

# Question: Who survived more: males or females? 
survival_by_gender = df.groupby('sex')['survived'].mean()
print("Survival Rate by Gender:\n", survival_by_gender)

# Question: Did passenger class affect survival chances? 
survival_by_class = df.groupby('pclass')['survived'].mean()
print("\nSurvival Rate by Class:\n", survival_by_class)

# 4. Data Visualization [cite: 18, 30]
plt.figure(figsize=(12, 5))

# Bar chart of survival by gender [cite: 19, 41]
plt.subplot(1, 3, 1)
sns.barplot(x="sex", y="survived", data=df, palette="viridis")
plt.title("Survival by Gender")

# Bar chart of survival by class [cite: 20, 44]
plt.subplot(1, 3, 2)
sns.barplot(x="pclass", y="survived", data=df, palette="magma")
plt.title("Survival by Class")

# Histogram of passenger ages 
plt.subplot(1, 3, 3)
df["age"].plot(kind="hist", bins=20, color="skyblue", edgecolor="black")
plt.title("Distribution of Passenger Ages")
plt.xlabel("Age")

plt.tight_layout()
plt.show()

# 5. Survival rate by age group 
# Creating age bins
bins = [0, 12, 18, 35, 60, 100]
labels = ['Child', 'Teenager', 'Young Adult', 'Adult', 'Senior']
df['age_group'] = pd.cut(df['age'], bins=bins, labels=labels)

plt.figure(figsize=(8, 5))
sns.barplot(x="age_group", y="survived", data=df, palette="coolwarm")
plt.title("Survival Rate by Age Group")
plt.ylabel("Survival Probability")
plt.show()
